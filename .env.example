# Supabase
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Publishable (anon) key — safe to expose to the browser. Starts with sb_publishable_
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret key — server-side ONLY. Starts with sb_secret_
SUPABASE_SECRET_KEY=

# Postgres — pooled for runtime (port 6543), direct for migrations (port 5432).
DATABASE_URL=
DIRECT_URL=

# App secrets
# Session signing secret. Use any long random string (e.g. `openssl rand -hex 32`).
SESSION_SECRET=
# Admin gate password (MVP only).
ADMIN_PASSWORD=

# Branding (optional, no leading/trailing quotes)
NEXT_PUBLIC_TEAM_NAME=Home Team
