# ============================================================================
# Supabase (required)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Postgres URLs from Supabase → Connect → ORMs.
# DATABASE_URL = transaction pooler (port 6543)  — runtime queries.
# DIRECT_URL   = session pooler   (port 5432)    — drizzle-kit migrations.
DATABASE_URL=
DIRECT_URL=

# Buckets (must already exist in Supabase → Storage → New bucket).
SUPABASE_KYC_BUCKET=kyc-artifacts
SUPABASE_PUBLIC_BUCKET=public-assets

# ============================================================================
# App
# ============================================================================
SESSION_SECRET=                         # openssl rand -hex 32 (legacy; still safe to keep)
ADMIN_PASSWORD=                         # MVP-only RBAC; replace before real money
NEXT_PUBLIC_APP_NAME=Rapid Bet
NEXT_PUBLIC_TEAM_NAME=Home Team
NEXT_PUBLIC_APP_URL=https://rapidbet-six.vercel.app

# ============================================================================
# Real-money master gate. Defaults closed. Stays false in Phase 1.
# ============================================================================
REAL_MONEY_ENABLED=false
PERMITTED_STATES=                       # CSV of US state codes (real money). Empty until counsel populates.
PLAY_PERMITTED_STATES=                  # CSV of US state codes (free-to-play). Empty = all 50 + DC.
PLAY_MIN_AGE_YEARS=18
MIN_AGE_YEARS=21
COMMISSION_RATE_BPS=100                 # 100 = 1.00%
STARTER_VIRTUAL_BALANCE_MINOR=10000     # $100.00 free-to-play seed

# ============================================================================
# Resend (transactional email) — get key at resend.com/api-keys
# ============================================================================
RESEND_API_KEY=
RESEND_FROM=Rapid Bet <onboarding@resend.dev>
RESEND_WEBHOOK_SECRET=                  # from resend.com/webhooks endpoint

# ============================================================================
# Firebase Cloud Messaging (push) — Firebase console → Project settings →
# Service accounts → Generate new private key
# Use either FIREBASE_SERVICE_ACCOUNT_JSON (full JSON blob) OR the three split
# vars below. Split form is easier in Vercel's UI.
# ============================================================================
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=                   # paste as one line; \n escapes are expanded by the adapter

# ============================================================================
# Trustly (deposits + withdrawals) — Phase 2. Sandbox-first.
# ============================================================================
TRUSTLY_ENV=sandbox                     # sandbox | production
TRUSTLY_USERNAME=
TRUSTLY_PASSWORD=
TRUSTLY_PRIVATE_KEY=                    # merchant RSA private key (PEM); \n escapes expanded
TRUSTLY_PUBLIC_KEY=                     # Trustly's public key for inbound webhook signature verification
TRUSTLY_NOTIFICATION_URL=               # https://your-app/api/webhooks/trustly

# ============================================================================
# Didit (KYC / identity / age) — Phase 2. Sandbox-first.
# ============================================================================
DIDIT_ENV=sandbox                       # sandbox | production
DIDIT_API_KEY=
DIDIT_WEBHOOK_SECRET=                   # HMAC secret from Didit dashboard
